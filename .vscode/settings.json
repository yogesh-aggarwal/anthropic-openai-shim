{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.vscode": true,
    "**/.ruff_cache": true,
    "**/.venv": true,
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    ".env": ".env.*",
    "litellm_config.yaml": "Makefile, .gitignore, *.yml",
    "providers.yaml": "models.yaml, models.*.yaml",
  },
  "python-envs.defaultEnvManager": "ms-python.python:venv"
}
